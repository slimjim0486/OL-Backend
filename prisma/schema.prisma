// ============================================

// Ollie's memory for personalized learning companion experience
model OllieMemory {
  id      String @id @default(uuid())
  childId String @unique
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  // Session context (for greetings)
  lastSessionAt DateTime?
  lastTopic     String? // Last topic/subject studied
  lastSubject   String? // Last subject enum value
  lastLessonId  String? // Last lesson ID for context

  // Weekly patterns (JSON - updated weekly by aggregation job)
  // Structure: { bestTimeOfDay: "16:00", avgSessionMinutes: 18, topSubjects: ["MATH", "SCIENCE"] }
  weeklyPatterns Json?

  // Recent struggles (JSON - rolling window, max 10)
  // Structure: [{ topic: "Fractions", subject: "MATH", attempts: 12, correctRate: 0.45, lastAttempt: Date }]
  recentStruggles Json?

  // Recent wins (JSON - rolling window, max 10)
  // Structure: [{ achievement: "Mastered multiplication", date: Date, context: "Got 10 in a row" }]
  recentWins Json?

  // Cumulative stats (for encouragement + summaries)
  totalLessonsCompleted Int   @default(0)
  totalCorrectAnswers   Int   @default(0)
  totalQuestionsAttempted Int @default(0)
  strongestSubjects     String[] // ["MATH", "SCIENCE"]
  growthAreas           String[] // ["READING", "WRITING"]
  persistenceScore      Float @default(0.5) // 0-1, measures retry behavior

  // Preferences (learned over time)
  preferredEncouragementStyle String? // "enthusiastic", "calm", "competitive"
  preferredTimeOfDay          String? // "morning", "afternoon", "evening"
  preferredSessionLength      Int?    // Average preferred session length in minutes

  // Memorable moments (JSON - capped at 50)
  // Structure: [{ type: "breakthrough", topic: "Fractions", description: "First perfect quiz", date: Date }]
  memorableMoments Json?

  // Greeting history to avoid repetition (JSON - last 5 greeting template IDs)
  // Structure: ["streak_continuation", "same_day_return", "optimal_time"]
  recentGreetingTemplates Json?

  // Upcoming milestones for greeting context
  // Structure: { nextLevelXp: 150, badgesNearby: ["streak_7", "math_master"], streakMilestone: 7 }
  upcomingMilestones Json?

  // Last weekly aggregation timestamp
  lastWeeklyUpdate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
  @@index([lastSessionAt])
}

// Weekly parent summary generated by Ollie
model ParentMemorySummary {
  id       String @id @default(uuid())
  parentId String
  childId  String

  // Summary period
  periodStart DateTime
  periodEnd   DateTime

  // Generated narrative content
  headline         String  @db.Text // One compelling sentence
  weeklyNarrative  String? @db.Text // Full narrative summary
  weeklyHighlights Json?   // [{ type: "badge", description: "...", date: Date }]

  // Structured insights
  weeklyInsights Json? // { bestTime: "...", learningStyle: "...", persistenceScore: 8 }

  // Celebration moments
  celebrationMoments Json? // [{ type: "streak", description: "7-day streak!" }]

  // Focus areas
  focusAreas Json? // [{ subject: "READING", reason: "accuracy dropped", suggestion: "..." }]

  // Parent action suggestion
  parentActionSuggestion String? @db.Text

  // Coming up / next goals
  upcomingGoals Json? // [{ type: "badge", name: "Math Master", progress: "3 more lessons" }]

  // Translation status
  originalLanguage  String @default("en")
  translatedTo      String? // Target language if translated
  translatedContent Json?   // Translated sections

  // Status
  status         ParentSummaryStatus @default(DRAFT)
  generatedAt    DateTime            @default(now())
  sentAt         DateTime?           // When email was sent
  viewedAt       DateTime?           // When parent viewed in app

  // Generation metadata
  tokensUsed Int     @default(0)
  modelUsed  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([childId, periodStart, periodEnd])
  @@index([parentId])
  @@index([childId])
  @@index([status, periodEnd])
}

enum ParentSummaryStatus {
  DRAFT     // Generated but not sent
  READY     // Ready to send
  SENT      // Email sent
  VIEWED    // Parent viewed in app
}

// ============================================
// TEACHER PORTAL - FILE EXPORTS
// ============================================

// Status of an export job
enum ExportStatus {
  QUEUED     // Waiting in queue
  PROCESSING // Being generated
  COMPLETED  // Ready for download
  FAILED     // Generation failed
  EXPIRED    // File has been deleted (after retention period)
}

// Type of export format
enum ExportFormat {
  PDF
  PPTX
  QTI
}

// Teacher export records - tracks all exports for the Downloads section
model TeacherExport {
  id        String  @id @default(uuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Source content
  contentId    String
  content      TeacherContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentTitle String         // Snapshot of title at export time

  // Export details
  format     ExportFormat
  filename   String        // Original filename (e.g., "Fractions Lesson - Orba.pptx")
  fileSize   Int?          // Size in bytes

  // R2 Storage
  r2Key      String?       // R2 object key
  r2Url      String?       // Public CDN URL for download

  // External references (for PPTX)
  presentationId String?   // Presenton presentation ID
  editUrl        String?   // Presenton edit URL (if user wants to edit)

  // Job tracking
  status       ExportStatus @default(QUEUED)
  errorMessage String?      // Error details if failed

  // Email notification
  emailSent    Boolean   @default(false)
  emailSentAt  DateTime?

  // Timestamps
  createdAt   DateTime  @default(now())
  completedAt DateTime? // When export finished
  expiresAt   DateTime? // When file will be auto-deleted (optional retention policy)

  @@index([teacherId, createdAt])
  @@index([teacherId, status])
  @@index([status, createdAt]) // For cleanup jobs
}

// ============================================
// TEACHER PORTAL - DOCUMENT ANALYSIS JOBS
// ============================================

model TeacherDocumentAnalysis {
  id        String  @id @default(uuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  filename String?
  mimeType String

  status       DocumentAnalysisStatus @default(QUEUED)
  result       Json?
  errorMessage String?

  tokensUsed Int?
  modelUsed  String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([teacherId, createdAt])
  @@index([teacherId, status])
}

// ============================================
// BREVO BEHAVIORAL EMAIL TRACKING
// ============================================

model TeacherTriggerLog {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  triggerName String // e.g., "credits_50_percent", "inactive_7_days"
  monthKey    String // e.g., "2026-0" for January 2026
  sentAt      DateTime @default(now())
  metadata    Json? // Optional additional data

  @@index([teacherId])
  @@index([triggerName])
  @@index([teacherId, triggerName])
}

model ContentDripEnrollment {
  id        String   @id @default(uuid())
  teacherId String   @unique
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  status      DripStatus @default(ACTIVE)
  currentStep Int        @default(0)
  totalSteps  Int        @default(5)

  // Snapshot of onboarding data at enrollment time
  primarySubject String
  gradeLevel     String
  curriculumType String?
  currentTopic   String
  upNextTopic    String?

  // Scheduling
  nextDeliveryAt DateTime
  lastDeliveryAt DateTime?
  enrolledAt     DateTime @default(now())
  completedAt    DateTime?

  // Generated content tracking
