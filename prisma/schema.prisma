  studentGroup String? // Target student group
  gradeLevel   String?

  // Generation parameters
  parameters Json // Input params for regeneration

  // AI metadata
  tokensUsed Int     @default(0)
  modelUsed  String?

  // Status
  status CommunicationStatus @default(DRAFT)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([teacherId, type])
}

enum CommunicationType {
  PARENT_EMAIL
  REPORT_CARD_COMMENT
}

enum CommunicationStatus {
  DRAFT
  APPROVED
  SENT
}

// ============================================
// TEACHER PORTAL - REVIEW SUMMARIES (Monthly/Yearly)
// ============================================

model TeacherReviewSummary {
  id        String       @id @default(uuid())
  teacherId String
  teacher   Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  agentId   String
  agent     TeacherAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Review period
  type        ReviewType
  periodLabel String  // "January 2026", "2025-2026 School Year"
  periodStart DateTime
  periodEnd   DateTime
  schoolYear  String? // "2025-2026"

  // Generated content
  executiveSummary   String @db.Text
  lessonsDelivered   Json   // { total, bySubject: { MATH: 15, ... } }
  assessmentsGiven   Json   // { total, byType: { quiz: 10, ... } }
  standardsCovered   Json   // { total, newlyMastered, gaps }
  studentGrowth      Json   // { summary, highlights }
  attentionAreas     Json   // [{ area, description, suggestedAction }]
  upcomingFocus      Json   // [{ topic, rationale }]
  recommendations    Json   // [{ recommendation, priority }]
  handoverNotes      String? @db.Text // For yearly reviews - next teacher info

  // AI metadata
  tokensUsed Int     @default(0)
  modelUsed  String?

  // Status
  status ReviewStatus @default(DRAFT)

