// ============================================================
// TEACHER INTELLIGENCE PLATFORM
// ============================================================

model TeacherStreamEntry {
  id        String @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Raw input
  content String @db.Text

  // AI-extracted metadata
  extractedTags    Json?   // { subjects: [], topics: [], standards: [], signals: [] }
  extractionStatus String  @default("pending") // pending, processing, completed, failed

  // Teacher corrections to tags (training signal)
  tagCorrections Json? // { dismissed: [], added: [], corrected: [] }

  // Links to other entities (built by graph engine)
  linkedMaterialIds String[]
  linkedStandardIds String[]
  linkedEntryIds    String[]

  // Metadata
  pinned   Boolean @default(false)
  archived Boolean @default(false)

  // Back-relation for graph node
  graphNode TeachingGraphNode?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId, createdAt(sort: Desc)])
  @@index([teacherId, pinned])
  @@index([teacherId, archived])
}

enum GraphNodeType {
  TOPIC           // "Fractions", "Water cycle" — the anchor nodes, sized by weight
  STREAM_ENTRY    // A teacher's note from the stream
  MATERIAL        // A generated or imported teaching material
  // STANDARD removed — standards are invisible metadata on TOPIC nodes (linkedStandardCodes)
}

model TeachingGraphNode {
  id        String @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Node identity
  type       GraphNodeType
  label      String         // Human-readable: "Fractions", "Water cycle", NOT "UK.KS2.Y6.MA.NFR.8"

  // For TOPIC nodes: invisible curriculum metadata (never displayed as nodes)
  linkedStandardCodes String[] // e.g. ["UK.KS2.Y6.MA.NFR.1", "UK.KS2.Y6.MA.NFR.2"]

  // For STREAM_ENTRY nodes: reference back to the stream entry
  streamEntryId String? @unique
  streamEntry   TeacherStreamEntry? @relation(fields: [streamEntryId], references: [id])

  // For MATERIAL nodes: reference back to the material
  materialId    String? @unique
  material      TeacherMaterial? @relation(fields: [materialId], references: [id])

  // Visual properties (calculated)
  weight        Float    @default(0)   // Determines node size (TOPIC: count of connected entries + materials)
  subject       String?                // For color coding: "mathematics", "science", "english"
  lastTouchedAt DateTime?

  // Canvas planning (synced from canvas auto-save)
  plannedForTerm   Boolean  @default(false) // Topic appears on a non-archived canvas
  plannedWeekLabel String?                  // Nearest TimeColumnNode label, e.g. "Week 3"

  // Connections
  edges         TeachingGraphEdge[] @relation("sourceEdges")
  incomingEdges TeachingGraphEdge[] @relation("targetEdges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, type, label])
  @@index([teacherId])
  @@index([teacherId, type])
  @@index([teacherId, plannedForTerm])
}

enum EdgeType {
  ABOUT           // Stream entry or material is ABOUT a topic
  GENERATED_FROM  // Material was generated from a stream entry
  RELATED         // Two topics co-occur in stream entries
  SEQUENCE        // Teacher covered topic A then topic B (temporal)
  REFLECTS_ON     // Stream entry reflects on a material's outcome
  PREREQUISITE    // Directed: prereq_topic → dependent_topic (derived from LearningStandard.prerequisites)
}

model TeachingGraphEdge {
  id        String @id @default(cuid())
  teacherId String

  sourceId String
  source   TeachingGraphNode @relation("sourceEdges", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId String
  target   TeachingGraphNode @relation("targetEdges", fields: [targetId], references: [id], onDelete: Cascade)

  // Edge properties
  type   EdgeType
  weight Float   @default(1)

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, type])
  @@index([teacherId])
}

enum IntelligenceMaterialType {
  WORKSHEET
  QUIZ
  FLASHCARDS
  INFOGRAPHIC
  SUMMARY
  RETEACH_ACTIVITY
  PARENT_UPDATE
  SUB_PLAN
  LESSON_PLAN
  AUDIO_UPDATE
}

model TeacherMaterial {
  id        String @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Content
  title   String
  type    IntelligenceMaterialType
  content Json
  pdfUrl  String?

  // Auto-tags (from generation context)
  subject    String
  topics     String[]
  standards  String[]
  gradeLevel String
  curriculum String

  // Source tracking
  sourceStreamEntryId String?
  sourceGraphNodeId   String?

  // Teacher interaction
  approved    Boolean @default(false)
  edited      Boolean @default(false)
  editDiff    Json?
  rating      Int?
  usedInClass Boolean @default(false)
  notes       String? @db.Text

  // Outcome tracking (lightweight feedback loop)
  outcomeRating   OutcomeRating?
  outcomeNotes    String?        @db.Text
  outcomeRatedAt  DateTime?

  // Usage tracking
  timesDownloaded Int @default(0)
  timesShared     Int @default(0)

  // Parent bridge
  sharedUpdate SharedParentUpdate?

  // Back-relation for graph node
  graphNode TeachingGraphNode?

  // Edit Intelligence Loop (Phase 4.9)
  edits MaterialEdit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId, createdAt(sort: Desc)])
  @@index([teacherId, subject])
  @@index([teacherId, type])
}

enum OutcomeRating {
  WORKED
  NEEDED_TWEAKS
  DIDNT_WORK
}

enum NudgeType {
  CURRICULUM_GAP
  PREFERENCE_LEARNED
  PACING_AHEAD
  PACING_BEHIND
  RETEACH_SUGGESTION
  COLLECTIVE_INSIGHT
  PREREQUISITE_GAP   // "X is a prereq for next week's Y" — derived from LearningStandard.prerequisites
}

model TeacherNudge {
  id        String @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  type     NudgeType
  content  String @db.Text
  priority Int    @default(0)

  // Context
  relatedTopicId    String?
  relatedStandardId String?

  // Structured action context — populated by each nudge generator with the
  // routing data the frontend needs when the teacher clicks "Take Action".
  // Shape (frontend-readable):
  //   { actionType: 'view_standards' | 'reteach_material' | 'view_weekly_prep'
  //                 | 'view_preferences' | 'view_insight',
  //     subject?: string, topicLabel?: string, standardCode?: string,
  //     materialId?: string, materialTitle?: string }
  actionContext Json?

  // State
  shown     Boolean @default(false)
  dismissed Boolean @default(false)
  actedOn   Boolean @default(false)

  showAfter DateTime  @default(now())
  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([teacherId, shown, dismissed])
}

// Cross-teacher aggregated insights keyed by curriculum standard code.
// Populated by the weekly collectiveInsightsAggregationJob. Read by
// nudgeService.generateCollectiveInsightNudges to surface community signal
// as COLLECTIVE_INSIGHT nudges.
//
// Privacy: rows are only written once MIN_TEACHER_THRESHOLD distinct
// teachers have contributed signals for a (standardCode, curriculum, grade,
// signalType) tuple. No teacherIds, student names, or raw content are
// persisted — only aggregated counts and themes that themselves appear
// across multiple teachers. Anonymization is enforced at aggregation time.
model CollectiveInsight {
  id String @id @default(cuid())

  // Scope — the join key from teacher topics via linkedStandardCodes
  standardCode   String // e.g. "UK.KS2.Y6.MA.NFR.8"
  curriculumType String // "BRITISH", "AMERICAN", "IB", "INDIAN_CBSE", ...
  gradeRange     String // Matches Teacher.gradeRange verbatim: "6", "6-8", "K-2"
  signalType     String // "reteach", "success", "concern", "observation", "idea"

  // Aggregated counts (k-anonymity enforced: teacherCount >= threshold)
  teacherCount Int // Distinct teachers who contributed
  signalCount  Int // Total raw signals aggregated

  // Aggregated patterns (JSON structure):
  //   {
  //     themes: [ { phrase: "visual fraction bars", teacherCount: 4 }, ... ],
  //     topTopics: [ "fraction bars", "equivalent fractions" ],
  //     signalTypeBreakdown: { reteach: 12, success: 3 }
  //   }
  // Individual phrases must themselves appear in >= 2 teachers' signals
  // before being retained, so no single teacher's language is exposed.
  aggregatedPatterns Json

  lastComputedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([standardCode, curriculumType, gradeRange, signalType])
  @@index([curriculumType, gradeRange])
  @@index([standardCode])
  @@index([lastComputedAt])
}

model TeacherPreferenceProfile {
  id        String @id @default(cuid())
  teacherId String @unique
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Learned preferences
  vocabularyLevel     String?
  preferredFormats    String[]
  difficultyBias      String?
  averageLessonLength String?

  // Teaching rhythm patterns
  weeklyPattern Json?
  topicDuration Json?

  // Edit patterns
  commonEdits Json?

  // Derived from stream analysis
  reflectionFrequency String?
  planningHorizon     String?

  // Confidence scores for each preference dimension
  confidenceScores Json?

  // ============================================
  // Edit Intelligence Loop (Phase 4.9)
  // ============================================

  // Aggregate edit activity counters
  totalEdits          Int      @default(0)
  totalApprovedNoEdit Int      @default(0)   // Materials approved/downloaded/shared without edits
  editRate            Float?                  // edits / (edits + approvedNoEdit) — lower is better

  // Learned tendencies from edit diffs (analyzed by Gemini per edit, aggregated here)
  vocabularyTendency  String?   // "simplifies_consistently", "elevates_consistently", "neutral"
  difficultyTendency  String?   // "makes_easier_consistently", "makes_harder_consistently", "neutral"
  lengthTendency      String?   // "shortens_consistently", "lengthens_consistently", "neutral"
  toneTendency        String?   // "more_formal", "more_casual", "more_encouraging", "neutral"

  // Specific learned patterns with confidence scores. Array of objects:
  // [
  //   { pattern: "prefers visual models over abstract notation", confidence: 0.85, sampleSize: 12 },
  //   { pattern: "always adds real-world examples", confidence: 0.72, sampleSize: 8 },
  // ]
  learnedPatterns     Json?

  // Per-material-type edit preferences:
  // {
  //   WORKSHEET: { avgEditsPerMaterial: 2.1, commonEdits: ["simplifies vocabulary", "adds visual supports"] },
  //   QUIZ: { avgEditsPerMaterial: 0.8, commonEdits: ["reduces question count"] },
  // }
  typePreferences     Json?

  // When we last told the teacher "I've learned your preferences" (Ollie whisper)
  lastLearnedNotifiedAt DateTime?

  lastUpdatedAt DateTime @updatedAt
}

// ============================================
// Edit Intelligence Loop (Phase 4.9)
// ============================================
// Every edit the teacher makes to a generated material is recorded here.
// An async analysis job sends the diff to Gemini, extracts signals, and
// aggregates learned patterns into TeacherPreferenceProfile. These
// preferences are then fed back into the generation context so future
// materials need less editing.

model MaterialEdit {
  id         String @id @default(cuid())
  materialId String
  material   TeacherMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // What happened
  editType MaterialEditType

  // What changed
  sectionType     String?  // "introduction", "questions", "vocabulary", "instructions", "examples", etc.
  originalContent String?  @db.Text  // What Ollie generated
  newContent      String?  @db.Text  // What the teacher changed it to (null for DELETE / pending REGENERATE)

  // AI-extracted learning (populated async by editAnalysisJob)
  // Expected shape:
  // {
  //   vocabularyChange?: "simplified" | "elevated" | "no_change",
  //   difficultyChange?: "easier" | "harder" | "no_change",
  //   contentChange?: "added_examples" | "removed_fluff" | "changed_approach"
  //                 | "added_scaffolding" | "added_extension" | "other",
  //   formatChange?: "shorter" | "longer" | "restructured" | "no_change",
  //   toneChange?: "more_formal" | "more_casual" | "more_encouraging" | "no_change",
  //   specificPatterns?: string[],
  //   // For DELETE type:
  //   likelyReason?: "too_advanced" | "too_basic" | "off_topic" | "redundant"
  //                | "wrong_format" | "unnecessary",
  //   // For ADD type:
  //   missingElement?: "examples" | "scaffolding" | "visual_support"
  //                  | "real_world_context" | "differentiation" | "instructions"
  //                  | "extension_activity" | "other",
  // }
  extractedSignals Json?

  // Analysis status
  analyzed   Boolean  @default(false)
  analyzedAt DateTime?

  createdAt DateTime @default(now())

  @@index([teacherId, createdAt(sort: Desc)])
  @@index([materialId])
  @@index([teacherId, analyzed])
}

enum MaterialEditType {
  REGENERATE   // Regenerated a section entirely — strong negative signal
  DELETE       // Removed content — content should not have existed
  ADD          // Added new content manually — generation missed something
  TEXT_EDIT    // Modified existing text in place — wording/tone/vocabulary change
}

// ============================================================
// TEACHER INTELLIGENCE — FUTURE PHASE MODELS
// ============================================================

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model MaterialImportJob {
  id        String @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  totalFiles Int
  processed  Int @default(0)
  succeeded  Int @default(0)
  failed     Int @default(0)
  status     ImportStatus @default(PENDING)
  errors     Json? // [{ fileName, error }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId, status])
}

model SharedParentUpdate {
  id         String @id @default(cuid())
  materialId String @unique
  material   TeacherMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  teacherId  String

  shortcode String @unique // 8-char random code
  isActive  Boolean @default(true)

  // Analytics
  viewCount     Int @default(0)
  ctaClickCount Int @default(0)

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([shortcode])
}

// ============================================================
// TEACHER INTELLIGENCE — UNIT PLANNING CANVAS (Phase 4-5)
// ============================================================

model TeacherCanvas {
  id          String  @id @default(cuid())
  teacherId   String
  teacher     Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  title       String            // "Autumn Term Plan", "Year 3 Maths Sequence"
  description String?

  // Full canvas state as JSON (viewport, items, connections)
  canvasData  Json              @default("{\"viewport\":{\"x\":0,\"y\":0,\"zoom\":1},\"items\":[],\"connections\":[]}")

  // Metadata
  isArchived   Boolean @default(false)
  planningHash String?            // Hash of {graphNodeId, weekLabel} tuples — skip sync if unchanged

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId])
  @@index([teacherId, isArchived])
}

// ============================================
// Student Entity Linking (Phase 2)
// ============================================

model StudentMention {
  id              String   @id @default(cuid())
  teacherId       String
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Identity (normalized)
  name            String            // "Ahmed", "Sophie", "Blue group"
  type            StudentEntityType // INDIVIDUAL, GROUP
  normalizedName  String            // Lowercase, trimmed: "ahmed", "blue group"

  // All stream entries mentioning this student/group
  streamEntryIds  String[]

  // Derived context (built up over time from mentions)
  subjects        String[]   // Subjects mentioned in connection with this student
  topics          String[]   // Topics mentioned in connection with this student
  signals         String[]   // Aggregated signals: "struggling with fractions", "strong reader"

  // Metadata
  mentionCount     Int       @default(1)
  firstMentionedAt DateTime  @default(now())
  lastMentionedAt  DateTime  @default(now())

  @@unique([teacherId, normalizedName])
  @@index([teacherId])
  @@index([teacherId, normalizedName])
}

enum StudentEntityType {
  INDIVIDUAL
  GROUP
}

// ============================================
// Unified Notification System
// ============================================

model TeacherNotification {
  id        String @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  type    TeacherNotificationType
  channel TeacherNotificationChannel

  title       String               // Short heading (bell/email)
  body        String   @db.Text    // Full message
  actionUrl   String?              // Deep link (e.g., "/library/abc123")
  actionLabel String?              // CTA text (e.g., "View material")
  metadata    Json?                // Flexible payload (materialId, streakCount, etc.)

  read      Boolean @default(false)
  dismissed Boolean @default(false)

  // Scheduling
  showAfter DateTime  @default(now())
  expiresAt DateTime?

  // Email tracking
  emailSentAt DateTime?
  emailId     String?              // Brevo/Resend message ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId, channel, read, dismissed])
  @@index([teacherId, channel, showAfter, expiresAt])
  @@index([teacherId, type])
}

enum TeacherNotificationType {
  // Bell notifications
  MATERIAL_SAVED
  MATERIAL_REMIXED
  STREAK_MILESTONE
  TERM_WRAPPED_READY

  // Email-only
  WEEKLY_DIGEST
  STREAK_REENGAGEMENT

  // Stream whispers (routed to existing nudge system)
  FIRST_NOTE_WELCOME
}

enum TeacherNotificationChannel {
  STREAM_WHISPER
  BELL
  EMAIL
  PUSH
}
