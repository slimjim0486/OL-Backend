  activities    Json // Detailed activity instructions
  materials     Json? // Materials list with locations
  emergencyInfo Json? // Emergency contacts, procedures
  studentNotes  Json? // Helpful students, special needs notes

  // Backup plans
  backupActivities Json? // "If tech fails" alternatives

  // Source lessons
  lessonIds String[] // IDs of TeacherContent used to generate

  // Export
  pdfUrl String? // Generated PDF URL

  // Generation metadata
  tokensUsed Int     @default(0)
  modelUsed  String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([teacherId, date])
  @@index([teacherId, createdAt])
}

// ============================================
// TEACHER PORTAL - IEP GOAL WRITER
// ============================================

model IEPGoalSession {
  id        String  @id @default(uuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Student info (privacy-safe - no names stored, just reference)
  studentIdentifier String? // Optional teacher reference (e.g., "Student A")
  gradeLevel        String // e.g., "3rd Grade", "K", "5th"

  // IEP Context
  disabilityCategory DisabilityCategory
  subjectArea        IEPSubjectArea

  // Present Levels
  presentLevels String  @db.Text // Current performance description
  strengths     String? @db.Text // Student strengths
  challenges    String? @db.Text // Areas of difficulty

  // Generated Content
  generatedGoals     Json // Array of SMART goal objects
  selectedGoals      Json? // Goals teacher selected/edited
  selectedAccommodations Json? // Accommodations teacher selected/edited
  accommodations     Json // Suggested accommodations by category
  progressMonitoring Json? // Progress monitoring suggestions

  // Goal timeline
  goalStartDate DateTime? @db.Date
  goalEndDate   DateTime? @db.Date // Typically 1 year from start

  // Generation metadata
  tokensUsed Int     @default(0)
  modelUsed  String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([teacherId, disabilityCategory])
  @@index([teacherId, createdAt])
}

// ============================================
// TEACHER PORTAL - BRAINSTORM
// ============================================

model BrainstormSession {
  id            String   @id @default(uuid())
  teacherId     String
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  title         String?  // Auto-generated or user-set

  // Curriculum context for this session (overrides teacher default)
  curriculumType CurriculumType?
  gradeLevel     String? // "3rd Grade", "Year 5", etc.
  subject        Subject?

  // Optional lesson context
  lessonId      String?
  lessonTitle   String?
  lessonContent String?  @db.Text // Snapshot at session start

  // Standards referenced in conversation (for quick reference)
  referencedStandardIds String[] @default([])

  // Conversation
  messages      BrainstormMessage[]

  // Token tracking
  totalTokens   Int      @default(0)
  flashTokens   Int      @default(0)
  proTokens     Int      @default(0)

  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([teacherId, createdAt])
  @@index([teacherId, curriculumType])
  @@index([teacherId, subject])
}

model BrainstormMessage {
  id          String   @id @default(uuid())
  sessionId   String
  session     BrainstormSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role        MessageRole // USER or ASSISTANT
  content     String   @db.Text
  model       String?  // "flash" or "pro" for assistant messages
  tokens      Int      @default(0)

  // Standards mentioned in this message
  standardReferences Json?  // [{id, notation, description}]
  imageUrls   String[] @default([])
  imagePrompt String?  @db.Text

  createdAt   DateTime @default(now())

  @@index([sessionId, createdAt])
}

enum DisabilityCategory {
  SPECIFIC_LEARNING_DISABILITY // SLD - Dyslexia, Dyscalculia, Dysgraphia
  SPEECH_LANGUAGE_IMPAIRMENT // Speech/Language
  OTHER_HEALTH_IMPAIRMENT // ADHD, health conditions
  AUTISM_SPECTRUM // ASD
  EMOTIONAL_DISTURBANCE // ED/EBD
  INTELLECTUAL_DISABILITY // ID
  DEVELOPMENTAL_DELAY // DD (ages 3-9)
  MULTIPLE_DISABILITIES // More than one category
  HEARING_IMPAIRMENT // DHH
  VISUAL_IMPAIRMENT // VI
  ORTHOPEDIC_IMPAIRMENT // OI
  TRAUMATIC_BRAIN_INJURY // TBI
  DEAF_BLINDNESS // Combined hearing and vision loss
}

enum IEPSubjectArea {
  READING_FLUENCY
  READING_COMPREHENSION
  WRITTEN_EXPRESSION
  MATH_CALCULATION
  MATH_PROBLEM_SOLVING
  SPEECH_ARTICULATION
  EXPRESSIVE_LANGUAGE
  RECEPTIVE_LANGUAGE
  SOCIAL_SKILLS
  BEHAVIOR_SELF_REGULATION
  EXECUTIVE_FUNCTIONING
  FINE_MOTOR
  GROSS_MOTOR
  ADAPTIVE_LIVING_SKILLS
  TRANSITION_VOCATIONAL
}

// ============================================
// ADMIN PORTAL - VC ANALYTICS DASHBOARD
// ============================================

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(ANALYST)

  // Security
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum AdminRole {
  SUPER_ADMIN // Full access, can create other admins
  ANALYST // Read-only access to analytics
}

// Activity tracking for DAU/WAU/MAU calculations
model ActivitySession {
  id      String @id @default(uuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  // Session timing
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int       @default(0)

  // Activity breakdown (JSON for flexibility)
  // Structure: { chat: 10, flashcards: 5, upload: 2, quiz: 3, lesson: 15 }
  activities Json @default("{}")

  // Gamification
  xpEarned         Int @default(0)
  lessonsStarted   Int @default(0)
  lessonsCompleted Int @default(0)

  // Denormalized date fields for efficient GROUP BY queries
  createdDate DateTime @db.Date // Date only (for DAU)
  weekStart   DateTime @db.Date // Monday of the week (for WAU)
  monthStart  DateTime @db.Date // First of the month (for MAU)

  // Device/platform (for segmentation)
  platform   String? // "ios", "android", "web"
  deviceType String? // "mobile", "tablet", "desktop"

  createdAt DateTime @default(now())

  // CRITICAL INDEXES for analytics queries
  @@index([createdDate]) // DAU queries
  @@index([childId, createdDate]) // Per-child activity
  @@index([weekStart]) // WAU queries
  @@index([monthStart]) // MAU queries
}

// Pre-computed daily metrics (populated by nightly job)
model DailyAnalyticsSnapshot {
  id   String   @id @default(uuid())
  date DateTime @unique @db.Date

  // User counts
  dauCount      Int @default(0) // Active users today
  newUsersCount Int @default(0) // New signups today

  // Engagement metrics
  totalSessions     Int   @default(0)
  avgSessionMinutes Float @default(0)
  totalXpAwarded    Int   @default(0)

  // Lesson metrics
  lessonsCreated   Int @default(0)
  lessonsCompleted Int @default(0)

  // Revenue metrics (snapshot at end of day)
  totalFreeUsers       Int     @default(0)
  totalFamilyUsers     Int     @default(0)
  totalFamilyPlusUsers Int     @default(0)
  estimatedMrr         Decimal @db.Decimal(10, 2)

  // Teacher portal
  teacherDauCount Int @default(0)

  computedAt DateTime @default(now())

  @@index([date])
}

// Pre-computed cohort retention (populated by weekly job)
model CohortRetentionSnapshot {
  id          String   @id @default(uuid())
  cohortMonth DateTime @db.Date // e.g., 2024-01-01
  monthNumber Int // 0 = signup month, 1, 2, ... 12

  // Metrics
  cohortSize    Int // Users who signed up in this month
  activeUsers   Int // Users active in monthNumber
  retentionRate Float // activeUsers / cohortSize * 100

  // Segmentation (optional)
  segment String? @default("all") // "all", "free", "paid", etc.

  computedAt DateTime @default(now())

  @@unique([cohortMonth, monthNumber, segment])
  @@index([cohortMonth])
  @@index([computedAt])
}

// ============================================
// CURRICULUM STANDARDS SYSTEM
// ============================================

// Curriculum jurisdiction (country/organization/board)
model CurriculumJurisdiction {
  id           String  @id @default(uuid())
  code         String  @unique // "UK_NATIONAL_CURRICULUM", "US_COMMON_CORE", "IB_PYP", "CBSE", "ICSE"
  name         String // "British National Curriculum"
  country      String? // "GB", "US", "IN", null for international
  organization String? // "IBO", "NCERT", etc.

  // Metadata
  sourceUrl    String? // Where standards came from
  lastSyncedAt DateTime?
  version      String? // "2014", "2024-25"

  // Relationships
  standardSets StandardSet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([country])
}

// Group of standards (e.g., "Year 1 Mathematics")
model StandardSet {
  id             String                 @id @default(uuid())
  jurisdictionId String
  jurisdiction   CurriculumJurisdiction @relation(fields: [jurisdictionId], references: [id])

  // Identification
  externalId String? // ID from source API (e.g., CSP GUID)
  code       String // "UK.KS1.Y1.MA", "PHASE_2_NUMBER"

  // Classification
  title           String // "Year 1 Mathematics"
  subject         Subject // MATH, SCIENCE, ENGLISH, etc.
  educationLevels String[] // ["Y1"] for Year 1, ["K"] for Kindergarten
  gradeLevel      Int? // Numeric grade (0=K, 1-6)
  ageRangeMin     Int? // Minimum age (e.g., 5)
  ageRangeMax     Int? // Maximum age (e.g., 7)
  phase           Int? // For IB PYP phases (1-4)
  keyStage        Int? // For British NC (1-2 for primary)

  // Metadata
  documentTitle String? // Source document name
  documentYear  String? // "2014"

  // Relationships
  standards LearningStandard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jurisdictionId, code])
  @@index([jurisdictionId, subject, gradeLevel])
  @@index([subject, educationLevels])
}

// Individual learning standard/outcome
model LearningStandard {
  id            String      @id @default(uuid())
  standardSetId String
  standardSet   StandardSet @relation(fields: [standardSetId], references: [id])

  // Identification
  externalId String? // ID from source (CSP GUID, ASN identifier)
  notation   String? // "UK.KS1.Y1.MA.NPV.1", "1.NBT.4"

  // Content
  description      String  @db.Text // The actual standard text
  shortDescription String? // Abbreviated version for UI

  // Hierarchy
  parentId String? // Parent standard for nested hierarchies
  parent   LearningStandard?  @relation("StandardHierarchy", fields: [parentId], references: [id])
  children LearningStandard[] @relation("StandardHierarchy")
  depth    Int                @default(0) // 0 = top level, 1 = child, etc.
  position Int                @default(0) // Sort order within parent

  // Classification
  strand         String? // "Number - Place Value", "Geometry", "Data Handling"
  conceptualArea String? // More specific topic area
  bloomsLevel    String? // "Remember", "Understand", "Apply", etc.
  isStatutory    Boolean @default(true) // For British NC: statutory vs non-statutory

  // Non-statutory guidance (British NC specific)
  guidance String? @db.Text // Notes and guidance (non-statutory)

  // Enterprise: Enhanced metadata for curriculum intelligence
  dokLevel            Int?       // Depth of Knowledge (1-4)
  prerequisites       String[]   // Standard IDs that should be taught first
  progressesTo        String[]   // Standard IDs this progresses toward
  commonMisconceptions String[]  // Common student misconceptions
  teachingStrategies  String[]   // Effective teaching strategies

  // Ancestor trail (for search/display)
  ancestorDescriptions String[] // ["Number and Operations", "Base Ten"]

  // Cross-curriculum mapping
  equivalentStandards StandardEquivalence[] @relation("SourceStandard")
  equivalentTo        StandardEquivalence[] @relation("TargetStandard")

  // Content alignment
  contentAlignments ContentStandardAlignment[]
  progressRecords   ChildStandardProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([standardSetId, notation])
  @@index([standardSetId, position])
  @@index([notation])
  @@index([strand, conceptualArea])
}

// Cross-curriculum equivalence mapping
model StandardEquivalence {
  id String @id @default(uuid())

  sourceStandardId String
  sourceStandard   LearningStandard @relation("SourceStandard", fields: [sourceStandardId], references: [id])

  targetStandardId String
  targetStandard   LearningStandard @relation("TargetStandard", fields: [targetStandardId], references: [id])

  // Mapping quality
  equivalenceType EquivalenceType // EXACT, PARTIAL, PREREQUISITE, ADVANCED
  confidence      Float           @default(0.8) // 0.0 - 1.0
  notes           String?         @db.Text // Explanation of the mapping

  // Verification
  verifiedBy String? // "AI", "EXPERT", "COMMUNITY"
  verifiedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([sourceStandardId, targetStandardId])
  @@index([sourceStandardId])
  @@index([targetStandardId])
}

// Link content (lessons, quizzes, flashcards) to standards
model ContentStandardAlignment {
  id String @id @default(uuid())

  // Polymorphic content reference
  contentType AlignableContentType // LESSON, QUIZ, FLASHCARD_DECK, TEACHER_CONTENT
  contentId   String // ID of the content item

  standardId String
  standard   LearningStandard @relation(fields: [standardId], references: [id])

  // Alignment quality
  alignmentStrength Float   @default(1.0) // 0.0 - 1.0 (how well it covers the standard)
  isPrimary         Boolean @default(false) // Is this the main standard for the content?

  // How alignment was determined
  alignedBy String? // "AI", "TEACHER", "SYSTEM"

  createdAt DateTime @default(now())

  @@unique([contentType, contentId, standardId])
  @@index([standardId])
  @@index([contentType, contentId])
}

// Track child's progress on specific standards
model ChildStandardProgress {
  id String @id @default(uuid())

  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  standardId String
  standard   LearningStandard @relation(fields: [standardId], references: [id])

  // Progress tracking
  status       StandardMasteryStatus @default(NOT_STARTED)
  masteryScore Float? // 0.0 - 1.0

  // Evidence
  attemptsCount   Int       @default(0)
  correctCount    Int       @default(0)
  lastAttemptAt   DateTime?
  firstMasteredAt DateTime?

  // Curriculum context (when this progress was earned)
  curriculumType CurriculumType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([childId, standardId])
  @@index([childId, status])
  @@index([childId, curriculumType])
}

// Curriculum switch history and gap analysis
model CurriculumSwitch {
  id String @id @default(uuid())

  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  // Switch details
  fromCurriculum CurriculumType
  toCurriculum   CurriculumType
  fromGrade      Int?
  toGrade        Int?

  // Analysis results (stored as JSON for flexibility)
  gapAnalysis        Json? // { gaps: [...], strengths: [...] }
  recommendedLessons Json? // Suggested catch-up content

  // Status
  analysisCompletedAt DateTime?
  acknowledgedAt      DateTime? // Parent saw the analysis

  createdAt DateTime @default(now())

  @@index([childId])
}

// ============================================
// VIRAL SHARING & REFERRAL SYSTEM
// ============================================

// Referral codes for parents and teachers
model ReferralCode {
  id   String @id @default(uuid())
  code String @unique // e.g., "SARAH-AB12" - readable, opaque

  // Owner (one of these will be set)
  parentId  String?  @unique
  parent    Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  teacherId String?  @unique
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Stats
  totalReferrals      Int @default(0) // Total signups using this code
  successfulReferrals Int @default(0) // Conversions (trial -> paid)

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  referrals         Referral[]
  shareableContents ShareableContent[]

  @@index([code])
}

// Individual referral tracking
model Referral {
  id             String       @id @default(uuid())
  referralCodeId String
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)

  // Who was referred (one of these will be set after signup)
  referredParentId  String?  @unique
  referredParent    Parent?  @relation("ReferredParent", fields: [referredParentId], references: [id], onDelete: SetNull)
  referredTeacherId String?  @unique
  referredTeacher   Teacher? @relation("ReferredTeacher", fields: [referredTeacherId], references: [id], onDelete: SetNull)

  // Tracking
  channel ShareChannel // WhatsApp, Email, Instagram, Link, etc.
  status  ReferralStatus @default(PENDING)

  // Attribution
  attributedAt DateTime  @default(now()) // When the referral code was used
  signedUpAt   DateTime? // When they created an account
  subscribedAt DateTime? // When they became paid subscriber

  // Rewards
  referrerRewardId  String? // Stripe coupon ID or subscription credit ID
  refereeDiscountId String? // Stripe coupon ID applied to referee
  referrerRewarded  Boolean @default(false)
  refereeRewarded   Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime // 30-day attribution window

  // Relations
  rewards ReferralReward[]

  @@index([referralCodeId])
  @@index([status])
  @@index([channel])
  @@index([createdAt])
}

// Shareable content snapshots (privacy-safe, immutable)
model ShareableContent {
  id    String @id @default(uuid())
  token String @unique // Opaque share token in URL

  // Owner (parent creates, teacher can create for audio updates)
  parentId  String?
  parent    Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Content type
  contentType ShareableContentType

  // Privacy-safe snapshot data (no child IDs, names, or PII)
  snapshotData Json // Pre-rendered, privacy-safe content

  // Metadata (for OG tags)
  title       String
  description String?
  imageUrl    String? // Pre-generated OG image stored in R2

  // Optional referral code embedding
  referralCodeId String?
  referralCode   ReferralCode? @relation(fields: [referralCodeId], references: [id])

  // Stats
  viewCount  Int @default(0)
  shareCount Int @default(0)

  // Status
  isActive  Boolean   @default(true)
  expiresAt DateTime? // Optional expiry for time-sensitive content

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  shareEvents ShareEvent[]

  @@index([token])
  @@index([parentId])
  @@index([teacherId])
  @@index([contentType])
}

// Share tracking for analytics
model ShareEvent {
  id                 String            @id @default(uuid())
  shareableContentId String?
  shareableContent   ShareableContent? @relation(fields: [shareableContentId], references: [id], onDelete: SetNull)

  // Who shared
  parentId  String?
  teacherId String?

  // Where
  channel  ShareChannel
  platform String? // iOS, Android, Web

  // Result
  wasOpened         Boolean   @default(false)
  openedAt          DateTime?
  convertedToSignup Boolean   @default(false)

  // Timestamps
  createdAt DateTime @default(now())

  @@index([channel])
  @@index([createdAt])
  @@index([parentId])
  @@index([teacherId])
}

// Referral rewards ledger
model ReferralReward {
  id         String   @id @default(uuid())
  referralId String
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  // Recipient
  parentId  String?
  parent    Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Reward details
  rewardType     RewardType
  amount         Decimal?   @db.Decimal(10, 2) // For credits or monetary value
  stripeCouponId String? // Stripe coupon if applicable
  description    String

  // Status
  status    RewardStatus @default(PENDING)
  appliedAt DateTime?
  expiresAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())

  @@index([parentId])
  @@index([teacherId])
  @@index([status])
}

// Parent sharing preferences (per-child controls)
model ParentSharingPreferences {
  id       String @id @default(uuid())
  parentId String @unique
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  // Global settings
  enableSharing Boolean @default(true) // Master toggle

  // Per-child settings stored as JSON
  // Format: { [childId]: { showName: true, showAvatar: true, enablePrompts: true } }
  childSettings Json @default("{}")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

