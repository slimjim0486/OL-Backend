  updatedAt DateTime @updatedAt

  @@unique([agentId, type, periodStart])
  @@index([teacherId])
  @@index([teacherId, type])
  @@index([agentId, type, periodStart])
}

enum ReviewType {
  MONTHLY
  SEMESTER
  YEARLY
}

enum ReviewStatus {
  DRAFT
  REVIEWED
  SHARED
}

// ============================================
// DTC PRODUCT PACKAGE ENUMS
// ============================================

enum PackageCategory {
  CORE          // Starter Kit, Semester Saver, Year-Round, Founding Teacher
  WEEKLY_BOX    // Weekly Classroom Box (recurring)
  SEASONAL      // Back-to-School, Test Prep, End-of-Year
  SPECIALTY     // Sub Plans, IEP Goals, Assessment, Communication
}

enum PackageTier {
  STARTER            // $29
  SEMESTER           // $89
  YEAR_ROUND         // $199
  FOUNDING_TEACHER   // $299
  WEEKLY_BOX         // $29/mo
  BACK_TO_SCHOOL     // $49
  TEST_PREP          // $69
  END_OF_YEAR        // $39
  SUB_PLAN_VAULT     // $39
  IEP_GOAL_BANK      // $49
  ASSESSMENT_ARSENAL // $49
  PARENT_COMM_KIT    // $39
}

enum PackagePurchaseStatus {
  PENDING        // Payment processing
  PAID           // Payment confirmed
  GENERATING     // Content being generated
  PARTIAL        // Some weeks delivered (progressive)
  READY          // All instant content ready for review
  COMPLETED      // All materials generated and delivered
  FAILED         // Generation failed
  REFUNDED       // Refunded
  CANCELLED      // Recurring cancelled
}

enum DeliveryType {
  INSTANT       // All at once (Starter Kit, Specialty)
  PROGRESSIVE   // Initial batch + weekly drops (Semester, Year-Round)
  RECURRING     // Weekly drops forever (Weekly Box)
}

enum PackageMaterialStatus {
  PKG_PENDING
  PKG_GENERATING
  PKG_GENERATED
  PKG_APPROVED
  PKG_EDITED
  PKG_REGENERATING
  PKG_FAILED
}

