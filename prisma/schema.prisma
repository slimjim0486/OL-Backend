  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime? // When status changed to PUBLISHED

  @@index([teacherId])
  @@index([teacherId, status])
  @@index([teacherId, createdAt])
}

// ============================================
// TEACHER PORTAL - SUBSTITUTE PLANS
// ============================================

model SubstitutePlan {
  id        String  @id @default(uuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Plan metadata
  title      String // e.g., "Sub Plan - Dec 23, 2025"
  date       DateTime @db.Date // Date the sub plan is for
  gradeLevel String? // Grade level (e.g., "3rd Grade", "K-2")

  // Schedule
  schedule Json // Array of time blocks with activities

  // Classroom info (optional, teacher can choose to include)
  classroomInfo Json? // Seating chart ref, routines, attention signals

